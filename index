<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <title>Web3.bond · 连接去中心化世界的信任纽带</title>
    <style>
        /* ===== Reset & Base ===== */
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #6C3CE1;
            --primary-light: #8B5CF6;
            --secondary: #00D4FF;
            --gold: #F7C948;
            --gold-light: #FDE68A;
            --bg-dark: #080816;
            --bg-card: rgba(255, 255, 255, 0.04);
            --text-primary: #FFFFFF;
            --text-secondary: rgba(255, 255, 255, 0.7);
            --text-muted: rgba(255, 255, 255, 0.4);
            --radius: 20px;
            --shadow-glow: 0 0 60px rgba(108, 60, 225, 0.15);
            --transition: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        html {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            scroll-behavior: smooth;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body {
            min-height: 100vh;
            overflow-x: hidden;
            background: var(--bg-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        /* ===== Canvas Background ===== */
        #particles-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* ===== Glow Orbs ===== */
        .glow-orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(120px);
            pointer-events: none;
            z-index: 0;
            opacity: 0.5;
            animation: orbFloat 12s ease-in-out infinite alternate;
        }
        .glow-orb--1 {
            width: 600px;
            height: 600px;
            top: -200px;
            right: -200px;
            background: radial-gradient(circle, rgba(108, 60, 225, 0.35), transparent 70%);
            animation-delay: 0s;
        }
        .glow-orb--2 {
            width: 500px;
            height: 500px;
            bottom: -150px;
            left: -150px;
            background: radial-gradient(circle, rgba(0, 212, 255, 0.25), transparent 70%);
            animation-delay: -4s;
        }
        .glow-orb--3 {
            width: 400px;
            height: 400px;
            top: 40%;
            left: 50%;
            transform: translateX(-50%);
            background: radial-gradient(circle, rgba(247, 201, 72, 0.12), transparent 70%);
            animation-delay: -8s;
        }

        @keyframes orbFloat {
            0% {
                transform: translate(0, 0) scale(1);
            }
            33% {
                transform: translate(30px, -20px) scale(1.1);
            }
            66% {
                transform: translate(-20px, 30px) scale(0.9);
            }
            100% {
                transform: translate(10px, -10px) scale(1.05);
            }
        }

        /* ===== 页面切换核心样式 ===== */
        .page {
            display: none;
            animation: fadeIn 0.4s ease;
            width: 100%;
        }
        .page.active {
            display: block;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* 返回首页按钮 */
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 999px;
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 0.9rem;
            transition: 0.3s;
            margin-bottom: 24px;
        }
        .back-btn:hover {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }

        /* 债券页面图片容器 */
        .bond-img-box {
            width: 100%;
            max-width: 800px;
            border-radius: var(--radius);
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.06);
            margin: 20px auto;
        }
        .bond-img-box img {
            width: 100%;
            height: auto;
            display: block;
        }

        /* ===== Main Container ===== */
        .container {
            position: relative;
            z-index: 1;
            max-width: 1200px;
            width: 100%;
            min-height: 90vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
            gap: 48px;
        }

        /* ===== Hero Section ===== */
        .hero {
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
            max-width: 900px;
            width: 100%;
        }

        /* Badge / Tag */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 18px;
            border-radius: 100px;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.08);
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.3px;
            color: var(--text-secondary);
            text-transform: uppercase;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            margin-bottom: 4px;
        }
        .badge .dot {
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--secondary);
            animation: pulseDot 2s ease-in-out infinite;
        }
        @keyframes pulseDot {
            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }
            50% {
                opacity: 0.3;
                transform: scale(0.6);
            }
        }

        /* Main Title */
        .title {
            font-size: clamp(3rem, 12vw, 7rem);
            font-weight: 900;
            line-height: 1.05;
            letter-spacing: -0.04em;
            background: linear-gradient(135deg, var(--primary-light) 0%, var(--secondary) 50%, var(--gold-light) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 80px rgba(108, 60, 225, 0.2);
            animation: titleGlow 6s ease-in-out infinite alternate;
            position: relative;
        }
        @keyframes titleGlow {
            0% {
                filter: brightness(1);
            }
            100% {
                filter: brightness(1.15);
            }
        }

        .title .highlight {
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            position: relative;
        }
        .title .highlight::after {
            content: '';
            position: absolute;
            bottom: 2px;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, var(--gold), var(--gold-light));
            border-radius: 4px;
            opacity: 0.4;
            filter: blur(2px);
        }

        /* Subtitle */
        .subtitle {
            font-size: clamp(1rem, 2.5vw, 1.6rem);
            font-weight: 400;
            color: var(--text-secondary);
            max-width: 640px;
            line-height: 1.6;
            letter-spacing: 0.02em;
            margin-top: 4px;
            padding: 0 12px;
        }
        .subtitle strong {
            color: var(--text-primary);
            font-weight: 600;
            background: linear-gradient(135deg, var(--secondary), var(--primary-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Divider */
        .divider {
            width: 60px;
            height: 2px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            border-radius: 4px;
            margin: 8px auto 0;
            opacity: 0.5;
        }

        /* ===== Cards ===== */
        .cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            width: 100%;
            max-width: 960px;
            margin-top: 8px;
        }

        .card {
            background: var(--bg-card);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: var(--radius);
            padding: 28px 24px 24px;
            transition: all var(--transition);
            position: relative;
            overflow: hidden;
            text-align: left;
            box-shadow: var(--shadow-glow);
            cursor: pointer;
        }
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border-radius: var(--radius);
            padding: 1px;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 50%, rgba(255, 255, 255, 0.03));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
        }
        .card:hover {
            transform: translateY(-6px);
            border-color: rgba(255, 255, 255, 0.12);
            box-shadow: 0 20px 60px rgba(108, 60, 225, 0.15);
            background: rgba(255, 255, 255, 0.07);
        }

        .card__icon {
            font-size: 1.8rem;
            margin-bottom: 14px;
            display: inline-block;
            line-height: 1;
            filter: drop-shadow(0 0 20px rgba(108, 60, 225, 0.2));
        }

        .card__title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.01em;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .card__title .accent {
            font-size: 0.65rem;
            font-weight: 600;
            color: var(--text-muted);
            letter-spacing: 0.3px;
            text-transform: uppercase;
            background: rgba(255, 255, 255, 0.05);
            padding: 2px 10px;
            border-radius: 100px;
            border: 1px solid rgba(255, 255, 255, 0.04);
        }
        .card__title .accent.gold {
            color: var(--gold);
            border-color: rgba(247, 201, 72, 0.15);
        }
        .card__title .accent.blue {
            color: var(--secondary);
            border-color: rgba(0, 212, 255, 0.15);
        }
        .card__title .accent.purple {
            color: var(--primary-light);
            border-color: rgba(139, 92, 246, 0.15);
        }

        .card__desc {
            font-size: 0.92rem;
            font-weight: 400;
            color: var(--text-secondary);
            line-height: 1.65;
            letter-spacing: 0.01em;
        }

        .card__line {
            width: 32px;
            height: 2px;
            border-radius: 4px;
            margin-top: 16px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            opacity: 0.5;
            transition: all var(--transition);
        }
        .card:hover .card__line {
            width: 48px;
            opacity: 0.8;
        }

        /* Card color variants */
        .card--trust .card__line {
            background: linear-gradient(90deg, var(--primary-light), var(--secondary));
        }
        .card--bond .card__line {
            background: linear-gradient(90deg, var(--gold), var(--gold-light));
        }
        .card--future .card__line {
            background: linear-gradient(90deg, var(--secondary), var(--primary-light));
        }

        /* ===== Footer ===== */
        .footer {
            width: 100%;
            max-width: 960px;
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
            padding-top: 32px;
            margin-top: 8px;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            flex-wrap: wrap;
            gap: 16px 24px;
        }

        .footer__copy {
            font-size: 0.8rem;
            font-weight: 400;
            color: var(--text-muted);
            letter-spacing: 0.02em;
        }
        .footer__copy a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color var(--transition);
        }
        .footer__copy a:hover {
            color: var(--text-secondary);
        }

        .footer__socials {
            display: flex;
            gap: 20px;
            align-items: center;
        }
        .footer__socials a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 500;
            letter-spacing: 0.02em;
            transition: all var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 0;
            border-bottom: 1px solid transparent;
        }
        .footer__socials a:hover {
            color: var(--text-primary);
            border-bottom-color: var(--primary-light);
        }
        .footer__socials a .social-icon {
            font-size: 1.1rem;
            line-height: 1;
        }

        /* ===== Responsive ===== */
        @media (max-width: 1024px) {
            .container {
                padding: 32px 16px;
                gap: 40px;
                min-height: 80vh;
            }
            .cards {
                gap: 16px;
            }
            .card {
                padding: 22px 18px 20px;
            }
        }

        @media (max-width: 768px) {
            body {
                padding: 16px;
            }
            .container {
                padding: 24px 12px;
                gap: 32px;
                min-height: 70vh;
            }
            .hero {
                gap: 14px;
            }
            .badge {
                font-size: 10px;
                padding: 4px 14px;
            }
            .title {
                font-size: clamp(2.4rem, 14vw, 4rem);
            }
            .subtitle {
                font-size: clamp(0.9rem, 2.8vw, 1.15rem);
                padding: 0 4px;
            }
            .divider {
                width: 40px;
            }

            .cards {
                grid-template-columns: 1fr;
                gap: 14px;
                max-width: 480px;
            }
            .card {
                padding: 20px 18px 18px;
                text-align: center;
                display: flex;
                flex-direction: column;
                align-items: center;
            }
            .card__title {
                font-size: 1rem;
                justify-content: center;
                flex-wrap: wrap;
            }
            .card__desc {
                font-size: 0.85rem;
                text-align: center;
                max-width: 320px;
            }
            .card__line {
                margin-top: 14px;
                width: 40px;
            }
            .card:hover .card__line {
                width: 56px;
            }
            .card__icon {
                font-size: 1.5rem;
                margin-bottom: 10px;
            }

            .footer {
                flex-direction: column;
                align-items: center;
                text-align: center;
                padding-top: 24px;
                gap: 12px;
            }
            .footer__socials {
                gap: 16px;
            }
            .footer__socials a {
                font-size: 0.75rem;
            }

            .glow-orb--1 {
                width: 300px;
                height: 300px;
                top: -100px;
                right: -100px;
            }
            .glow-orb--2 {
                width: 250px;
                height: 250px;
                bottom: -80px;
                left: -80px;
            }
            .glow-orb--3 {
                width: 200px;
                height: 200px;
                top: 30%;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 16px 8px;
                gap: 28px;
            }
            .title {
                font-size: clamp(2rem, 15vw, 3.2rem);
            }
            .subtitle {
                font-size: clamp(0.8rem, 3vw, 1rem);
            }
            .card {
                padding: 16px 14px 14px;
            }
            .card__title {
                font-size: 0.95rem;
            }
            .card__desc {
                font-size: 0.8rem;
            }
            .footer__copy {
                font-size: 0.7rem;
            }
        }

        /* ===== Scrollbar ===== */
        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-dark);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--primary-light);
        }

        /* ===== Selection ===== */
        ::selection {
            background: var(--primary);
            color: #fff;
        }
    </style>
</head>
<body>

    <!-- ===== Glow Orbs ===== -->
    <div class="glow-orb glow-orb--1" aria-hidden="true"></div>
    <div class="glow-orb glow-orb--2" aria-hidden="true"></div>
    <div class="glow-orb glow-orb--3" aria-hidden="true"></div>

    <!-- ===== Canvas Particles ===== -->
    <canvas id="particles-canvas" aria-hidden="true"></canvas>

    <!-- ===== 页面容器：首页 + 债券页面 ===== -->
    <main class="container" role="main">
        <!-- 首页页面 -->
        <div id="page-home" class="page active">
            <!-- Hero -->
            <section class="hero">
                <div class="badge">
                    <span class="dot"></span>
                    Web3 · DeFi · Trust
                </div>

                <h1 class="title">
                    Web3.<span class="highlight">bond</span>
                </h1>

                <p class="subtitle">
                    连接去中心化世界的 <strong>信任纽带</strong>
                    <br />
                    <span style="font-size:0.75em; color:var(--text-muted); font-weight:300;">
                        Connecting Trust in the Decentralized World
                    </span>
                </p>

                <div class="divider" aria-hidden="true"></div>
